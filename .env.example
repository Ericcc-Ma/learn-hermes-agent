# ═══════════════════════════════════════════════════════
# LLM Provider: anthropic | deepseek | openai | openai_compat
# ═══════════════════════════════════════════════════════
LLM_PROVIDER=anthropic

# ---- Anthropic (LLM_PROVIDER=anthropic) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- DeepSeek (LLM_PROVIDER=deepseek) ----
# Model: deepseek-chat, deepseek-reasoner
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# ---- OpenAI (LLM_PROVIDER=openai) ----
# Model: gpt-4o, gpt-4o-mini, etc.
# OPENAI_API_KEY=sk-your-openai-key

# ---- OpenAI-Compatible (LLM_PROVIDER=openai_compat) ----
# 通义千问 (Qwen):   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 智谱 (GLM):         LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 月之暗面 (Moonshot): LLM_BASE_URL=https://api.moonshot.cn/v1
# 零一万物 (Yi):       LLM_BASE_URL=https://api.lingyiwanwu.com/v1
# Ollama (本地):       LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=your-api-key
# LLM_BASE_URL=https://api.example.com/v1

# ---- Model ID (根据 provider 设置) ----
# Anthropic: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5
# DeepSeek:  deepseek-chat, deepseek-reasoner
# OpenAI:    gpt-4o, gpt-4o-mini
# Qwen:      qwen-plus, qwen-max
# GLM:       glm-4-flash, glm-4-plus
# Moonshot:  moonshot-v1-8k
MODEL_ID=claude-sonnet-4-6
